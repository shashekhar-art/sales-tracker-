<?php

/**
 * @file
 * Sales Tracker module hooks.
 */

use Drupal\Core\Form\FormStateInterface;

/**
 * Build a menubar render array for a given active key.
 */
function _sales_tracker_menubar_render($active) {
  return [
    '#theme' => 'sales_tracker_menubar',
    '#active' => $active,
    '#is_admin' => \Drupal::currentUser()->hasPermission('administer sales tracker'),
  ];
}

/**
 * Implements hook_preprocess_HOOK() for each main module template.
 * Injects {{ menubar }} variable so each template renders the button bar at the top.
 */
function sales_tracker_preprocess_sales_tracker_dashboard(&$v)        { $v['menubar'] = _sales_tracker_menubar_render('dashboard'); }
function sales_tracker_preprocess_sales_tracker_history(&$v)          { $v['menubar'] = _sales_tracker_menubar_render('history'); }
function sales_tracker_preprocess_sales_tracker_admin(&$v)            { $v['menubar'] = _sales_tracker_menubar_render('admin'); }
function sales_tracker_preprocess_sales_tracker_accounts(&$v)         { $v['menubar'] = _sales_tracker_menubar_render('accounts'); }
function sales_tracker_preprocess_sales_tracker_account_detail(&$v)   { $v['menubar'] = _sales_tracker_menubar_render('accounts'); }
function sales_tracker_preprocess_sales_tracker_visits_history(&$v)   { $v['menubar'] = _sales_tracker_menubar_render('history'); }
function sales_tracker_preprocess_sales_tracker_reports(&$v)          { $v['menubar'] = _sales_tracker_menubar_render('reports'); }
function sales_tracker_preprocess_sales_tracker_proctor(&$v)          { $v['menubar'] = _sales_tracker_menubar_render('proctor'); }
function sales_tracker_preprocess_sales_tracker_proctor_region(&$v)   { $v['menubar'] = _sales_tracker_menubar_render('proctor'); }
function sales_tracker_preprocess_sales_tracker_proctor_district(&$v) { $v['menubar'] = _sales_tracker_menubar_render('proctor'); }
function sales_tracker_preprocess_sales_tracker_proctor_employee(&$v) { $v['menubar'] = _sales_tracker_menubar_render('proctor'); }

/**
 * Implements hook_form_alter() to prepend the menubar to module forms.
 */
function sales_tracker_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  static $active_map = [
    'sales_tracker_plan_form'     => 'plan',
    'sales_tracker_checkin_form'  => 'dashboard',
    'sales_tracker_visit_form'    => 'visit',
    'sales_tracker_account_form'  => 'accounts',
    'sales_tracker_target_form'   => 'targets',
    'sales_tracker_settings'      => 'admin',
  ];
  if (!isset($active_map[$form_id])) {
    return;
  }
  $rendered = (string) \Drupal::service('renderer')->renderInIsolation(_sales_tracker_menubar_render($active_map[$form_id]));
  $existing_prefix = $form['#prefix'] ?? '';
  $form['#prefix'] = $rendered . $existing_prefix;
}

/**
 * Implements hook_theme().
 */
function sales_tracker_theme($existing, $type, $theme, $path) {
  return [
    'sales_tracker_menubar' => [
      'variables' => ['active' => '', 'is_admin' => FALSE],
      'template' => 'sales-tracker-menubar',
    ],
    'sales_tracker_dashboard' => [
      'variables' => [
        'plan' => NULL,
        'planned_items' => [],
        'history' => [],
        'flags' => [],
        'today_visits' => [],
        'today_counts' => [],
        'stats' => [],
      ],
      'template' => 'sales-tracker-dashboard',
    ],
    'sales_tracker_history' => [
      'variables' => ['rows' => []],
      'template' => 'sales-tracker-history',
    ],
    'sales_tracker_admin' => [
      'variables' => ['summary' => [], 'flags' => []],
      'template' => 'sales-tracker-admin',
    ],
    'sales_tracker_accounts' => [
      'variables' => ['accounts' => [], 'filters' => []],
      'template' => 'sales-tracker-accounts',
    ],
    'sales_tracker_account_detail' => [
      'variables' => ['account' => NULL, 'visits' => []],
      'template' => 'sales-tracker-account-detail',
    ],
    'sales_tracker_visits_history' => [
      'variables' => ['visits' => [], 'filters' => [], 'flask_static_base' => 'http://127.0.0.1:5000/static/'],
      'template' => 'sales-tracker-visits-history',
    ],
    'sales_tracker_reports' => [
      'variables' => ['period' => 'week', 'stats' => []],
      'template' => 'sales-tracker-reports',
    ],
    'sales_tracker_proctor' => [
      'variables' => ['regions' => [], 'totals' => []],
      'template' => 'sales-tracker-proctor',
    ],
    'sales_tracker_proctor_region' => [
      'variables' => ['region' => NULL, 'districts' => [], 'totals' => []],
      'template' => 'sales-tracker-proctor-region',
    ],
    'sales_tracker_proctor_district' => [
      'variables' => ['district' => NULL, 'region' => NULL, 'employees' => [], 'totals' => []],
      'template' => 'sales-tracker-proctor-district',
    ],
    'sales_tracker_proctor_employee' => [
      'variables' => ['employee' => NULL, 'stats' => [], 'recent' => [], 'flags' => []],
      'template' => 'sales-tracker-proctor-employee',
    ],
  ];
}

/**
 * Implements hook_form_user_login_form_alter().
 * After login, redirect to /sales/dashboard so users never land on the
 * default /user/<id> profile page (which exposes unstyled core tabs).
 */
function sales_tracker_form_user_login_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $form['#submit'][] = '_sales_tracker_login_redirect';
}

function _sales_tracker_login_redirect(array &$form, FormStateInterface $form_state) {
  // Honour any explicit ?destination=... in the URL; otherwise go to the dashboard.
  $request = \Drupal::request();
  if ($request->query->has('destination')) {
    return;
  }
  $form_state->setRedirect('sales_tracker.dashboard');
}
