<div class="sales-tracker">
{{ menubar }}

  <section class="st-card st-card--focal">
    <header class="st-card__head">
      <div>
        <span class="st-eyebrow st-eyebrow--muted">
          <a href="{{ path('sales_tracker.proctor') }}">India</a> &middot; Region
        </span>
        <h1 class="st-card__title">{{ region.name|default('Region') }}</h1>
      </div>
      <span class="st-card__sub">{{ districts|length }} district{{ districts|length == 1 ? '' : 's' }}</span>
    </header>

    <div class="st-period-summary">
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.today|default(0) }}</span>
        <span class="st-stat-tile__label">Today</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.week|default(0) }}</span>
        <span class="st-stat-tile__label">Week</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.month|default(0) }}</span>
        <span class="st-stat-tile__label">Month</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.quarter|default(0) }}</span>
        <span class="st-stat-tile__label">Quarter</span>
      </div>
    </div>
  </section>

  {% if districts %}
    <div class="st-territory-grid">
      {% for d in districts %}
        <a href="{{ path('sales_tracker.proctor.district', {did: d.id}) }}" class="st-card st-territory-card st-card--clickable">
          <header class="st-territory-card__heading">
            <h3>{{ d.name }}</h3>
            {% if d.code %}<span class="st-chip">{{ d.code }}</span>{% endif %}
          </header>
          <div class="st-territory-card__nums">
            <div>
              <span class="st-stat-tile__num st-num">{{ d.employees|default(0) }}</span>
              <span class="st-stat-tile__label">Employees</span>
            </div>
            <div>
              <span class="st-stat-tile__num st-num">{{ d.today|default(0) }}</span>
              <span class="st-stat-tile__label">Today</span>
            </div>
            <div>
              <span class="st-stat-tile__num st-num">{{ d.week|default(0) }}</span>
              <span class="st-stat-tile__label">Week</span>
            </div>
            <div>
              <span class="st-stat-tile__num st-num">{{ d.month|default(0) }}</span>
              <span class="st-stat-tile__label">Month</span>
            </div>
          </div>
          <span class="st-drill-link">View employees →</span>
        </a>
      {% endfor %}
    </div>
  {% else %}
    <div class="st-card">
      <div class="st-empty">
        <div class="st-empty__title">No districts in this region</div>
        <div class="st-empty__body">Seed the districts table for this region to drill down.</div>
      </div>
    </div>
  {% endif %}

  <nav class="st-bottom-nav" aria-label="Primary mobile">
    <a href="{{ path('sales_tracker.dashboard') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 12L12 3l9 9"/><path d="M5 10v10h14V10"/>
      </svg><span>Home</span>
    </a>
    <a href="{{ path('sales_tracker.proctor') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/>
      </svg><span>India</span>
    </a>
    <a href="{{ path('sales_tracker.proctor.region', {rid: region.id|default(0)}) }}" class="st-bottom-nav__item st-bottom-nav__item--active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z"/>
        <circle cx="12" cy="9" r="2.5"/>
      </svg><span>Region</span>
    </a>
    <a href="{{ path('sales_tracker.reports') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 3v18h18"/><path d="M7 15l4-4 3 3 5-6"/>
      </svg><span>Reports</span>
    </a>
    <a href="{{ path('sales_tracker.admin') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
      </svg><span>Admin</span>
    </a>
  </nav>
</div>
