<div class="sales-tracker">
{{ menubar }}

  <section class="st-card st-card--focal">
    <header class="st-card__head">
      <div>
        <span class="st-eyebrow st-eyebrow--muted">Account</span>
        <h1 class="st-card__title">{{ account.name }}</h1>
      </div>
      <div>
        {% set ttone = account.type == 'doctor' ? 'doctor' : (account.type == 'chemist' ? 'chemist' : 'stockist') %}
        <span class="st-account-type-tag st-account-type-tag--{{ ttone }}">{{ account.type|capitalize }}</span>
      </div>
    </header>

    <div class="st-grid-2">
      <div class="st-field">
        <span class="st-eyebrow st-eyebrow--muted">Specialty</span>
        <div>{{ account.specialty|default('—') }}</div>
      </div>
      <div class="st-field">
        <span class="st-eyebrow st-eyebrow--muted">District</span>
        <div>{{ account.district_name|default(account.district_id ? '#' ~ account.district_id : '—') }}</div>
      </div>
      <div class="st-field">
        <span class="st-eyebrow st-eyebrow--muted">Phone</span>
        <div>{{ account.phone|default('—') }}</div>
      </div>
      <div class="st-field">
        <span class="st-eyebrow st-eyebrow--muted">Email</span>
        <div>{{ account.email|default('—') }}</div>
      </div>
    </div>
    {% if account.address %}
      <div class="st-field">
        <span class="st-eyebrow st-eyebrow--muted">Address</span>
        <div>{{ account.address }}</div>
      </div>
    {% endif %}
    <div class="st-form-card__footer">
      <a href="/sales/accounts/{{ account.id }}/edit" class="st-btn st-btn--primary">Edit</a>
      <a href="/sales/visit?account_id={{ account.id }}" class="st-btn st-btn--secondary">Log visit</a>
      <a href="/sales/accounts" class="st-btn st-btn--ghost">Back to list</a>
    </div>
  </section>

  {# Recent visits for this account #}
  <section class="st-card st-datatable" aria-labelledby="visitsTitle">
    <header class="st-datatable__head">
      <h2 id="visitsTitle" class="st-card__title">Recent visits</h2>
      <span class="st-card__sub">{{ visits|length }} total</span>
    </header>
    {% if visits %}
      <table>
        <thead>
          <tr><th>When</th><th>Employee</th><th>Outcome</th><th>Notes</th></tr>
        </thead>
        <tbody>
          {% for v in visits %}
            <tr class="st-visit-row">
              <td data-label="When">{{ v.checkin_time }}</td>
              <td data-label="Employee">{{ v.employee_name|default('—') }}</td>
              <td data-label="Outcome">
                {% set otone = v.outcome == 'met' ? 'matched' : (v.outcome == 'rescheduled' ? 'manual' : 'unmatched') %}
                <span class="st-badge st-badge--{{ otone }}">{{ v.outcome|default('—')|replace({'_': ' '})|capitalize }}</span>
              </td>
              <td data-label="Notes">{{ v.visit_notes|default('—') }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <div class="st-empty"><div class="st-empty__body">No visits logged yet for this account.</div></div>
    {% endif %}
  </section>
</div>
