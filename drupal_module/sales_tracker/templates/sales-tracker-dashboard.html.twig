<div class="sales-tracker">
{{ menubar }}

  {# === BRANCH 1: No plan declared today === #}
  {% if not plan %}
    <section class="st-card st-card--focal" aria-labelledby="planTitle">
      <div class="st-empty">
        <svg class="st-empty__art" viewBox="0 0 120 120" fill="none" stroke="currentColor" aria-hidden="true">
          <rect class="em-fill-soft" x="22" y="28" width="64" height="76" rx="8" stroke="currentColor" stroke-width="1.5"/>
          <rect class="em-fill-white" x="40" y="22" width="28" height="10" rx="3" stroke="currentColor" stroke-width="1.5"/>
          <line x1="32" y1="50" x2="76" y2="50" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
          <line x1="32" y1="62" x2="68" y2="62" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
          <line x1="32" y1="74" x2="62" y2="74" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
          <path d="M88 38 c-6 0 -10 4 -10 10 0 7 10 18 10 18 s10 -11 10 -18 c0 -6 -4 -10 -10 -10 z"
                class="em-fill-white" stroke-width="1.5" stroke-dasharray="3 2"/>
          <circle cx="88" cy="48" r="3" class="em-accent" fill="currentColor" stroke="none"/>
        </svg>
        <div id="planTitle" class="st-empty__title">No plan declared yet</div>
        <div class="st-empty__body">Declare where you'll be today so check-ins can be scored.</div>
      </div>
    </section>

    <div class="st-links">{{ links }}</div>

  {# === BRANCH 2 & 3: Plan exists === #}
  {% else %}

    {# Compute last check-in (first row in history) #}
    {% set last_checkin = history|first %}

    {# Hero card with plan + last-check-in gauge #}
    <section class="st-card st-card--focal" aria-labelledby="planTitle">
      <div class="st-hero">
        <div class="st-hero__plan">
          <span class="st-eyebrow st-eyebrow--muted">Today &middot; plan</span>
          <h1 id="planTitle">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 style="color: var(--c-primary); vertical-align: -3px; margin-right: 6px;" aria-hidden="true">
              <path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
            {{ plan.planned_place_name }}
          </h1>
          <div class="st-hero__meta">
            {% if plan.planned_lat is not null and plan.planned_lon is not null %}
              <span class="st-chip st-chip--coord st-chip--enhanced">
                {% include '@sales_tracker/_st-geo.html.twig' with {
                  lat: plan.planned_lat,
                  lon: plan.planned_lon,
                  label: plan.planned_place_name|default('today\'s plan')
                } only %}
              </span>
            {% endif %}
            {% if plan.notes %}
              <span class="st-chip">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 5h16M4 12h10M4 19h16"/>
                </svg>
                {{ plan.notes }}
              </span>
            {% endif %}
          </div>
        </div>

        <aside class="st-hero__gauge">
          {% if last_checkin and last_checkin.match_score is not null %}
            {% set raw = last_checkin.match_score %}
            {% set pct = ((raw * 100) + 0.5) | round(0, 'floor') %}
            {% if pct >= 80 %}
              {% set tone = 'high' %}
            {% elseif pct >= 50 %}
              {% set tone = 'mid' %}
            {% else %}
              {% set tone = 'low' %}
            {% endif %}
            {% set score = pct / 100 %}
            {% set value_dash = 197.92 * score %}
            <svg class="st-gauge st-gauge--{{ tone }}" width="112" height="112" viewBox="-4 -4 108 108"
                 role="img" aria-label="Match score {{ pct }} percent — {{ tone }}">
              <circle class="st-gauge__track" cx="50" cy="50" r="42" fill="none" stroke-width="8"
                      stroke-linecap="round"
                      stroke-dasharray="197.92 263.89"
                      transform="rotate(135 50 50)"/>
              <circle class="st-gauge__value" cx="50" cy="50" r="42" fill="none" stroke-width="8"
                      stroke-linecap="round"
                      stroke-dasharray="{{ value_dash|number_format(2, '.', '') }} 263.89"
                      transform="rotate(135 50 50)"/>
              <text class="st-gauge__num" x="50" y="54" text-anchor="middle" font-size="24">
                {{ pct }}<tspan class="st-gauge__pct" font-size="13">%</tspan>
              </text>
              <text class="st-gauge__lbl" x="50" y="72" text-anchor="middle"
                    font-size="8" letter-spacing="1.4">MATCH</text>
            </svg>
            <span class="st-hero__gauge-label">Last check-in</span>
            <span class="st-hero__gauge-time">{{ last_checkin.checkin_time }}</span>
          {% else %}
            <svg class="st-gauge" width="112" height="112" viewBox="-4 -4 108 108"
                 role="img" aria-label="Awaiting first check-in today">
              <circle class="st-gauge__track" cx="50" cy="50" r="42" fill="none" stroke-width="8"
                      stroke-linecap="round" stroke-dasharray="197.92 263.89" transform="rotate(135 50 50)"/>
              <text class="st-gauge__num" x="50" y="55" text-anchor="middle" font-size="22" fill="var(--c-text-muted)">—</text>
              <text class="st-gauge__lbl" x="50" y="72" text-anchor="middle"
                    font-size="8" letter-spacing="1.4">AWAITING</text>
            </svg>
            <span class="st-hero__gauge-label">No check-in yet</span>
            <span class="st-hero__gauge-time st-muted">Hit "Check in now" when you arrive</span>
          {% endif %}
        </aside>
      </div>
    </section>

    {# === v2: today's visit-type counts strip ====================== #}
    {% set tc = today_counts|default({'doctor': 0, 'chemist': 0, 'stockist': 0, 'retailer': 0, 'wholesaler': 0, 'total': 0}) %}
    <div class="st-period-summary" aria-label="Today's visit-type counts">
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
        </span>
        <span class="st-stat-tile__num st-num">{{ tc.total|default(0) }}</span>
        <span class="st-stat-tile__label">Visits today</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__icon" style="background: var(--c-accent-50); color: var(--c-accent-dark);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M8 1a3 3 0 0 0-3 3v3a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
          </svg>
        </span>
        <span class="st-stat-tile__num st-num">{{ tc.doctor|default(0) }}</span>
        <span class="st-stat-tile__label">Doctors</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__icon" style="background: var(--c-primary-50); color: var(--c-primary-dark);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 3h14v6l-4 6 4 6v-2H5v2l4-6-4-6z"/>
          </svg>
        </span>
        <span class="st-stat-tile__num st-num">{{ tc.chemist|default(0) }}</span>
        <span class="st-stat-tile__label">Chemists</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__icon" style="background: var(--c-success-bg); color: var(--c-success-fg);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="7" width="18" height="14" rx="1"/><path d="M3 11h18M8 7V4h8v3"/>
          </svg>
        </span>
        <span class="st-stat-tile__num st-num">{{ tc.stockist|default(0) }}</span>
        <span class="st-stat-tile__label">Stockists</span>
      </div>
    </div>

    {# === v2: period tabs — day / week / month / quarter ============= #}
    {% if stats is defined and stats %}
      <section class="st-card">
        <nav class="st-tabs" aria-label="Period summary">
          <a href="#period-day" class="st-tabs__item st-tabs__item--active">Today</a>
          <a href="#period-week" class="st-tabs__item">Week</a>
          <a href="#period-month" class="st-tabs__item">Month</a>
          <a href="#period-quarter" class="st-tabs__item">Quarter</a>
        </nav>
        <div class="st-period-summary" style="margin-top: var(--sp-4);">
          {% for key, label in {'day': 'Today', 'week': 'Week', 'month': 'Month', 'quarter': 'Quarter'} %}
            {% set ps = stats[key]|default({}) %}
            <div class="st-card st-stat-tile" id="period-{{ key }}">
              <span class="st-stat-tile__num st-num">{{ ps.total_visits|default(0) }}</span>
              <span class="st-stat-tile__label">{{ label }} visits</span>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# === v2: planned account items — each with a Log visit link ====== #}
    {% if planned_items is defined and planned_items %}
      <section class="st-card" aria-labelledby="plannedTitle">
        <header class="st-card__head">
          <h2 id="plannedTitle" class="st-card__title">Planned today</h2>
          <span class="st-card__sub">{{ planned_items|length }} account{{ planned_items|length == 1 ? '' : 's' }}</span>
        </header>
        <ul class="st-planned-list">
          {% for it in planned_items %}
            {% set aid = it.account_id|default(it.id) %}
            {% set aname = it.account_name|default(it.name|default('Account #' ~ aid)) %}
            {% set atype = it.account_type|default(it.type|default('')) %}
            {% set alat = it.lat|default(it.account_lat|default(null)) %}
            {% set alon = it.lon|default(it.account_lon|default(null)) %}
            <li class="st-planned-item">
              <div>
                <a href="{{ path('sales_tracker.accounts.view', {id: aid}) }}" class="st-cell-place__name">{{ aname }}</a>
                {% if atype %}
                  {% set ttone = atype in ['doctor','chemist','stockist','retailer','wholesaler'] ? atype : 'stockist' %}
                  <span class="st-account-type-tag st-account-type-tag--{{ ttone }}">{{ atype|capitalize }}</span>
                {% endif %}
                {% if alat is not null and alon is not null %}
                  {% include '@sales_tracker/_st-geo.html.twig' with {
                    lat: alat, lon: alon, label: aname
                  } only %}
                {% endif %}
                {% if it.notes %}<div class="st-cell-place__sub">{{ it.notes }}</div>{% endif %}
              </div>
              <a href="{{ path('sales_tracker.visit', {}, {'query': {'account_id': aid}}) }}" class="st-btn st-btn--primary st-btn--sm">Log visit</a>
            </li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}

    {# === BRANCH 2: Plan exists but no check-ins yet — awaiting banner === #}
    {% if not last_checkin %}
      <div class="st-flash st-flash--info" role="status" style="margin-top: var(--sp-6);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v5"/><circle cx="12" cy="16" r="0.8" fill="currentColor"/>
        </svg>
        <span>Awaiting first check-in today. Hit "Check in now" once you arrive.</span>
      </div>

      <div class="st-links">{{ links }}</div>
    {% else %}

      {# === BRANCH 3: Plan + check-ins — KPI strip, dashboard grid (table + anomalies) === #}

      {# KPI computations — use |reduce so the running totals survive the for-loop scope #}
      {% set ci_count = history|length %}
      {% set match_scores = history|filter(h => h.match_score is not null)|map(h => h.match_score) %}
      {% set distances = history|filter(h => h.distance_km is not null)|map(h => h.distance_km) %}
      {% set match_n = match_scores|length %}
      {% set dist_n = distances|length %}
      {% set match_sum = match_scores|reduce((carry, v) => carry + v, 0) %}
      {% set dist_sum = distances|reduce((carry, v) => carry + v, 0) %}
      {% set avg_match = match_n > 0 ? (match_sum / match_n) : 0 %}
      {% set avg_distance = dist_n > 0 ? (dist_sum / dist_n) : 0 %}
      {% set avg_match_pct = ((avg_match * 100) + 0.5) | round(0, 'floor') %}

      {% if avg_match_pct >= 80 %}{% set m_tone = 'st-kpi__value--success' %}
      {% elseif avg_match_pct >= 50 %}{% set m_tone = 'st-kpi__value--warning' %}
      {% else %}{% set m_tone = 'st-kpi__value--danger' %}{% endif %}

      {% if avg_distance <= 0.5 %}{% set d_tone = 'st-kpi__value--success' %}
      {% elseif avg_distance <= 2 %}{% set d_tone = 'st-kpi__value--warning' %}
      {% else %}{% set d_tone = 'st-kpi__value--danger' %}{% endif %}

      {% set flag_count = flags is defined and flags ? flags|length : 0 %}
      {% if flag_count == 0 %}{% set a_tone = 'st-kpi__value--success' %}
      {% elseif flag_count < 3 %}{% set a_tone = 'st-kpi__value--warning' %}
      {% else %}{% set a_tone = 'st-kpi__value--danger' %}{% endif %}

      <div class="st-kpis">
        <div class="st-card st-kpi">
          <div class="st-kpi__label">Check-ins today</div>
          <div class="st-kpi__value st-num">{{ ci_count }}</div>
          <div class="st-kpi__sub">recorded so far</div>
        </div>

        <div class="st-card st-kpi">
          <div class="st-kpi__label">Avg match score</div>
          <div class="st-kpi__value st-num {{ m_tone }}"
               aria-label="Average match score {{ avg_match_pct }} percent">
            {{ avg_match_pct }}<span class="st-unit">%</span>
          </div>
          <div class="st-kpi__sub">across today</div>
        </div>

        <div class="st-card st-kpi">
          <div class="st-kpi__label">Avg distance</div>
          <div class="st-kpi__value st-num {{ d_tone }}"
               aria-label="Average distance {{ avg_distance|number_format(2) }} kilometres">
            {{ avg_distance|number_format(2) }}<span class="st-unit">km</span>
          </div>
          <div class="st-kpi__sub">from planned location</div>
        </div>

        <div class="st-card st-kpi">
          <div class="st-kpi__label">Open anomalies</div>
          <div class="st-kpi__value st-num {{ a_tone }}"
               aria-label="{{ flag_count }} open {{ flag_count == 1 ? 'anomaly' : 'anomalies' }}{% if flag_count %} — requires review{% endif %}">
            {% if flag_count > 0 %}
              <svg class="st-kpi__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3 L22 20 H2 Z"/><path d="M12 10v4"/><circle cx="12" cy="17" r="0.8" fill="currentColor"/>
              </svg>
            {% endif %}
            <span>{{ flag_count }}</span>
          </div>
          <div class="st-kpi__sub">last 24 hours</div>
        </div>
      </div>

      <div class="st-links">{{ links }}</div>

      {# Two-column layout: recent check-ins (2fr) + anomalies (1fr) #}
      <div class="st-dashboard-grid">
        <section class="st-card st-datatable" aria-labelledby="recentTitle">
          <header class="st-datatable__head">
            <h2 id="recentTitle" class="st-card__title">Recent check-ins</h2>
            <span class="st-card__sub">Most recent first</span>
          </header>
          <table>
            <thead>
              <tr>
                <th>Status</th>
                <th>Place</th>
                <th>Source</th>
                <th>Distance (km)</th>
                <th>Time</th>
                <th class="r">Flag</th>
              </tr>
            </thead>
            <tbody>
              {% for h in history %}
                {% if h.match_score is not null %}
                  {% set raw = h.match_score %}
                  {% set pct = ((raw * 100) + 0.5) | round(0, 'floor') %}
                {% else %}
                  {% set raw = 0 %}
                  {% set pct = 0 %}
                {% endif %}
                {% if pct >= 80 %}
                  {% set tone = 'high' %}
                  {% set row_tone = 'ok' %}
                {% elseif pct >= 50 %}
                  {% set tone = 'mid' %}
                  {% set row_tone = 'mid' %}
                {% else %}
                  {% set tone = 'low' %}
                  {% set row_tone = 'bad' %}
                {% endif %}
                {% set score = pct / 100 %}
                {% set value_dash = 197.92 * score %}
                {% set matched = (h.match_score is not null) and (pct >= 80) %}

                {% if h.distance_km is not null %}
                  {% set d = h.distance_km %}
                {% else %}
                  {% set d = 0 %}
                {% endif %}
                {% if d < 10 %}
                  {% set fill_pct = (10 - d) * 10 %}
                {% else %}
                  {% set fill_pct = 0 %}
                {% endif %}
                {% if d <= 0.5 %}
                  {% set dcolor = '#10B981' %}{% set dqual = 'near' %}{% set dqualtxt = 'Near' %}
                {% elseif d <= 2 %}
                  {% set dcolor = '#F59E0B' %}{% set dqual = 'mid' %}{% set dqualtxt = 'Mid' %}
                {% else %}
                  {% set dcolor = '#EF4444' %}{% set dqual = 'far' %}{% set dqualtxt = 'Far' %}
                {% endif %}

                <tr class="st-row--{{ row_tone }}">
                  <td data-label="Status">
                    {% if h.match_score is not null %}
                      <span class="st-score-cell" aria-label="Match score {{ pct }} percent">
                        <svg class="st-gauge st-gauge--{{ tone }}" width="36" height="36" viewBox="-4 -4 108 108" aria-hidden="true" focusable="false">
                          <circle class="st-gauge__track" cx="50" cy="50" r="42" fill="none" stroke-width="10"
                                  stroke-linecap="round" stroke-dasharray="197.92 263.89" transform="rotate(135 50 50)"/>
                          <circle class="st-gauge__value" cx="50" cy="50" r="42" fill="none" stroke-width="10"
                                  stroke-linecap="round"
                                  stroke-dasharray="{{ value_dash|number_format(2, '.', '') }} 263.89" transform="rotate(135 50 50)"/>
                        </svg>
                        <span class="st-num st-score-cell__num">{{ pct }}<span class="st-unit">%</span></span>
                        <span class="st-score-cell__tag st-score-cell__tag--{{ tone }}" aria-hidden="true">
                          {% if tone == 'high' %}High{% elseif tone == 'mid' %}Mid{% else %}Low{% endif %}
                        </span>
                      </span>
                    {% else %}
                      <span class="st-muted">—</span>
                    {% endif %}
                  </td>
                  <td data-label="Place">
                    <div class="st-cell-place__name">{{ h.actual_place_name|default('—') }}</div>
                    {% if h.actual_lat is defined and h.actual_lat is not null and h.actual_lon is not null %}
                      <div class="st-cell-place__sub">
                        {% include '@sales_tracker/_st-geo.html.twig' with {
                          lat: h.actual_lat,
                          lon: h.actual_lon,
                          label: h.actual_place_name|default('check-in')
                        } only %}
                      </div>
                    {% endif %}
                  </td>
                  <td data-label="Source">
                    {% if h.source == 'gps' %}
                      <span class="st-badge st-badge--gps">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <circle cx="8" cy="8" r="2"/><circle cx="8" cy="8" r="6"/>
                          <path d="M8 1v2M8 13v2M1 8h2M13 8h2"/>
                        </svg>
                        GPS
                      </span>
                    {% else %}
                      <span class="st-badge st-badge--manual">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M3 13l3-1 7-7-2-2-7 7-1 3z"/>
                        </svg>
                        Manual
                      </span>
                    {% endif %}
                  </td>
                  <td data-label="Distance">
                    {% if h.distance_km is not null %}
                      <span class="st-prox" title="Fuller bar means closer to planned location">
                        <svg class="st-prox__bar" width="120" height="10" viewBox="0 0 120 10"
                             role="img" aria-label="{{ d|number_format(2) }} kilometres from planned location — {{ dqualtxt }}">
                          <rect class="st-prox__bar-track" x="0" y="2" width="120" height="6" rx="3"/>
                          <rect x="0" y="2" width="{{ (fill_pct * 1.2)|number_format(2, '.', '') }}" height="6" rx="3" fill="{{ dcolor }}"/>
                        </svg>
                        <span class="st-num"><span class="st-prox__num">{{ d|number_format(2) }}</span><span class="st-unit">km</span></span>
                        <span class="st-prox__qual st-prox__qual--{{ dqual }}">{{ dqualtxt }}</span>
                      </span>
                    {% else %}
                      <span class="st-muted">—</span>
                    {% endif %}
                  </td>
                  <td data-label="Time">
                    <div class="st-cell-time__rel">{{ h.checkin_time }}</div>
                  </td>
                  <td data-label="Flag" class="r">
                    {% if h.match_score is null %}
                      <span class="st-badge st-badge--neutral">Pending</span>
                    {% elseif matched %}
                      <span class="st-badge st-badge--matched" role="status">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <circle cx="8" cy="8" r="7"/><path d="M5 8.5l2 2 4-4.5"/>
                        </svg>
                        Matched
                      </span>
                    {% else %}
                      <span class="st-badge st-badge--unmatched" role="status">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <circle cx="8" cy="8" r="7"/><path d="M5.5 5.5l5 5M10.5 5.5l-5 5"/>
                        </svg>
                        Not matched
                      </span>
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </section>

        <section class="st-card" aria-labelledby="anomaliesTitle">
          <header class="st-card__head">
            <h2 id="anomaliesTitle" class="st-card__title">Anomaly flags</h2>
            <span class="st-card__sub">Last 24 hours</span>
          </header>
          {% if flags is defined and flags %}
            <div class="st-anomaly-list" aria-live="polite">
              {% for f in flags %}
                <div class="st-anomaly-row" role="group" aria-label="Anomaly: {{ f.reason }}">
                  <span class="st-anomaly-row__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 3 L22 20 H2 Z"/><path d="M12 10v4"/><circle cx="12" cy="17" r="0.8" fill="currentColor"/>
                    </svg>
                  </span>
                  <div>
                    <div class="st-anomaly-row__reason">{{ f.actual_place_name|default('—') }}</div>
                    <div class="st-anomaly-row__meta">{{ f.reason }}</div>
                  </div>
                  <div>
                    <span class="st-badge st-badge--anomaly" role="status">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75"
                           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M8 2 L14.5 13.5 H1.5 Z"/><path d="M8 6.5v3.5"/><circle cx="8" cy="12" r="0.6" fill="currentColor"/>
                      </svg>
                      Anomaly
                      <span class="st-sr-only">Requires review</span>
                    </span>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <div class="st-empty" style="color: var(--c-success);">
              <svg class="st-empty__art" viewBox="0 0 120 120" fill="none" stroke="currentColor" aria-hidden="true">
                <path d="M60 16 L96 30 V60 C96 82 60 104 60 104 S24 82 24 60 V30 Z"
                      fill="var(--c-success-bg)" stroke-width="1.75"/>
                <path d="M44 60 L56 72 L78 48" stroke-width="2.5"
                      stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
              <div class="st-empty__title">All clear</div>
              <div class="st-empty__body">No unusual patterns detected in the last 24 hours.</div>
            </div>
          {% endif %}
        </section>
      </div>

    {% endif %}

  {% endif %}

