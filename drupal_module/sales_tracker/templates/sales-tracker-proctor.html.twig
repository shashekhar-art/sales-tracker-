<div class="sales-tracker">
{{ menubar }}

  <section class="st-card st-card--focal">
    <header class="st-card__head">
      <div>
        <span class="st-eyebrow st-eyebrow--muted">National rollup</span>
        <h1 class="st-card__title">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               style="color: var(--c-primary); vertical-align: -3px; margin-right: 6px;" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2c3 3.5 4.5 7.5 4.5 10s-1.5 6.5-4.5 10c-3-3.5-4.5-7.5-4.5-10s1.5-6.5 4.5-10z"/>
          </svg>
          India — Proctor
        </h1>
      </div>
      <div>
        <span class="st-card__sub">{{ regions|length }} state{{ regions|length == 1 ? '' : 's' }}/UT</span>
      </div>
    </header>

    {# India totals strip #}
    <div class="st-period-summary">
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.today|default(0) }}</span>
        <span class="st-stat-tile__label">Visits today</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.week|default(0) }}</span>
        <span class="st-stat-tile__label">This week</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.month|default(0) }}</span>
        <span class="st-stat-tile__label">This month</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.quarter|default(0) }}</span>
        <span class="st-stat-tile__label">This quarter</span>
      </div>
    </div>
  </section>

  {# Region cards — one per state / UT #}
  {% if regions %}
    <div class="st-territory-grid">
      {% for r in regions %}
        <a href="{{ path('sales_tracker.proctor.region', {rid: r.id}) }}" class="st-card st-territory-card st-card--clickable">
          <header class="st-territory-card__heading">
            <h3>{{ r.name }}</h3>
            <span class="st-account-type-tag st-account-type-tag--{{ r.type == 'ut' ? 'chemist' : 'doctor' }}">
              {{ r.type == 'ut' ? 'UT' : 'State' }}
            </span>
          </header>
          <div class="st-territory-card__nums">
            <div>
              <span class="st-stat-tile__num st-num">{{ r.employees|default(0) }}</span>
              <span class="st-stat-tile__label">Employees</span>
            </div>
            <div>
              <span class="st-stat-tile__num st-num">{{ r.today|default(0) }}</span>
              <span class="st-stat-tile__label">Today</span>
            </div>
            <div>
              <span class="st-stat-tile__num st-num">{{ r.week|default(0) }}</span>
              <span class="st-stat-tile__label">Week</span>
            </div>
            <div>
              <span class="st-stat-tile__num st-num">{{ r.month|default(0) }}</span>
              <span class="st-stat-tile__label">Month</span>
            </div>
          </div>
          <span class="st-drill-link">View districts →</span>
        </a>
      {% endfor %}
    </div>
  {% else %}
    <div class="st-card">
      <div class="st-empty">
        <div class="st-empty__title">No regions configured yet</div>
        <div class="st-empty__body">Seed the regions table to start seeing data.</div>
      </div>
    </div>
  {% endif %}

  <nav class="st-bottom-nav" aria-label="Primary mobile">
    <a href="{{ path('sales_tracker.dashboard') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 12L12 3l9 9"/><path d="M5 10v10h14V10"/>
      </svg><span>Home</span>
    </a>
    <a href="{{ path('sales_tracker.reports') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 3v18h18"/><path d="M7 15l4-4 3 3 5-6"/>
      </svg><span>Reports</span>
    </a>
    <a href="{{ path('sales_tracker.proctor') }}" class="st-bottom-nav__item st-bottom-nav__item--active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/>
      </svg><span>India</span>
    </a>
    <a href="{{ path('sales_tracker.accounts') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
      </svg><span>Accounts</span>
    </a>
    <a href="{{ path('sales_tracker.admin') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.2 4.2l2 2M17.8 17.8l2 2M2 12h3M19 12h3M4.2 19.8l2-2M17.8 6.2l2-2"/>
      </svg><span>Admin</span>
    </a>
  </nav>
</div>
