<div class="sales-tracker">
{{ menubar }}

  <section class="st-card st-card--focal">
    <header class="st-card__head">
      <div>
        <span class="st-eyebrow st-eyebrow--muted">
          <a href="{{ path('sales_tracker.proctor') }}">India</a> &middot;
          {% if region %}<a href="{{ path('sales_tracker.proctor.region', {rid: region.id}) }}">{{ region.name }}</a> &middot;{% endif %}
          District
        </span>
        <h1 class="st-card__title">{{ district.name|default('District') }}</h1>
      </div>
      <span class="st-card__sub">{{ employees|length }} employee{{ employees|length == 1 ? '' : 's' }}</span>
    </header>

    <div class="st-period-summary">
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.today|default(0) }}</span>
        <span class="st-stat-tile__label">Today</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.week|default(0) }}</span>
        <span class="st-stat-tile__label">Week</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.month|default(0) }}</span>
        <span class="st-stat-tile__label">Month</span>
      </div>
      <div class="st-card st-stat-tile">
        <span class="st-stat-tile__num st-num">{{ totals.quarter|default(0) }}</span>
        <span class="st-stat-tile__label">Quarter</span>
      </div>
    </div>
  </section>

  {% if employees %}
    <section class="st-card st-datatable" aria-labelledby="empTitle">
      <header class="st-datatable__head">
        <h2 id="empTitle" class="st-card__title">Employees in this district</h2>
        <span class="st-card__sub">Tap a row to drill into the individual</span>
      </header>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Today</th>
            <th>Week</th>
            <th>Month</th>
            <th>Quarter</th>
            <th class="r">Action</th>
          </tr>
        </thead>
        <tbody>
          {% for e in employees %}
            <tr>
              <td data-label="Name">
                <a href="{{ path('sales_tracker.proctor.employee', {eid: e.id}) }}" class="st-cell-place__name">{{ e.name }}</a>
                <div class="st-cell-place__sub">{{ e.email }}</div>
              </td>
              <td data-label="Today"><span class="st-num">{{ e.today|default(0) }}</span></td>
              <td data-label="Week"><span class="st-num">{{ e.week|default(0) }}</span></td>
              <td data-label="Month"><span class="st-num">{{ e.month|default(0) }}</span></td>
              <td data-label="Quarter"><span class="st-num">{{ e.quarter|default(0) }}</span></td>
              <td data-label="Action" class="r">
                <a href="{{ path('sales_tracker.proctor.employee', {eid: e.id}) }}" class="st-btn st-btn--ghost st-btn--sm">Detail</a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
  {% else %}
    <div class="st-card">
      <div class="st-empty">
        <div class="st-empty__title">No employees in this district</div>
        <div class="st-empty__body">Assign employees to this district to see them here.</div>
      </div>
    </div>
  {% endif %}

  <nav class="st-bottom-nav" aria-label="Primary mobile">
    <a href="{{ path('sales_tracker.dashboard') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 12L12 3l9 9"/><path d="M5 10v10h14V10"/>
      </svg><span>Home</span>
    </a>
    <a href="{{ path('sales_tracker.proctor') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/>
      </svg><span>India</span>
    </a>
    {% if region %}
      <a href="{{ path('sales_tracker.proctor.region', {rid: region.id}) }}" class="st-bottom-nav__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 21s-7-7.5-7-12a7 7 0 1 1 14 0c0 4.5-7 12-7 12z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg><span>Region</span>
      </a>
    {% endif %}
    <a href="#" class="st-bottom-nav__item st-bottom-nav__item--active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="7" width="18" height="14" rx="1"/><path d="M3 11h18"/>
      </svg><span>District</span>
    </a>
    <a href="{{ path('sales_tracker.reports') }}" class="st-bottom-nav__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 3v18h18"/><path d="M7 15l4-4 3 3 5-6"/>
      </svg><span>Reports</span>
    </a>
  </nav>
</div>
