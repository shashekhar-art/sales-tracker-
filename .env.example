# XAMPP defaults: MariaDB on localhost:3306, user "root" with EMPTY password.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=sales_tracker
FLASK_SECRET=replace-with-a-long-random-string

# Shared secret between Drupal module and Flask API. Pick something long and random.
API_KEY=change-me-to-a-long-random-string

GEO_THRESHOLD_KM=5
MATCH_THRESHOLD=0.6
